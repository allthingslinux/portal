# =============================================================================
# ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your actual values
# This file shows all available environment variables with examples
# 
# SIMPLIFIED SETUP:
# - .env: Main configuration (this template)
# - .env.local: Personal overrides (gitignored)
# - .env.example: This template file
#
# Environment-specific values are handled automatically by T3 Env defaults

# =============================================================================
# SITE CONFIGURATION (REQUIRED)
# =============================================================================
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_PRODUCT_NAME="AllThingsLinux Portal"
NEXT_PUBLIC_SITE_TITLE="AllThingsLinux Portal"
NEXT_PUBLIC_SITE_DESCRIPTION="Community portal for AllThingsLinux"
NEXT_PUBLIC_DEFAULT_LOCALE="en"
NEXT_PUBLIC_DEFAULT_THEME_MODE="system"
NEXT_PUBLIC_THEME_COLOR="#000000"
NEXT_PUBLIC_THEME_COLOR_DARK="#ffffff"

# =============================================================================
# AUTHENTICATION (REQUIRED)
# =============================================================================
BETTER_AUTH_SECRET="your-secret-key-here"

# Keycloak Configuration (Required)
KEYCLOAK_ID="portal"
KEYCLOAK_SECRET="your-keycloak-secret"
KEYCLOAK_ISSUER="http://localhost:8080/realms/portal"

# OAuth Providers (Optional)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# =============================================================================
# DATABASE (REQUIRED)
# =============================================================================
DATABASE_URL="postgresql://user:password@localhost:5432/portal"

# =============================================================================
# DOCKER CONFIGURATION (OPTIONAL)
# =============================================================================
# PostgreSQL version for Docker containers
POSTGRES_VERSION="17"

# Keycloak Database (for Docker setup)
KEYCLOAK_DB_NAME="keycloak"
KEYCLOAK_DB_USER="keycloak"
KEYCLOAK_DB_PASSWORD="keycloak"

# Keycloak Server Configuration
KEYCLOAK_HOSTNAME="localhost"
KEYCLOAK_LOG_LEVEL="INFO"
KEYCLOAK_METRICS_ENABLED="true"
KEYCLOAK_FEATURES=""

# Keycloak Admin Credentials
KEYCLOAK_ADMIN_USER="admin"
KEYCLOAK_ADMIN_PASSWORD="admin_password"

# Portal Admin User (for realm setup)
PORTAL_ADMIN_EMAIL="admin@portal.local"
PORTAL_ADMIN_PASSWORD="portal_admin_123"

# Client Configuration Arrays (comma-separated)
PORTAL_REDIRECT_URIS="http://localhost:3000/api/auth/oauth2/callback/keycloak"
PORTAL_WEB_ORIGINS="http://localhost:3000"
PORTAL_POST_LOGOUT_URIS="http://localhost:3000,http://localhost:3000/auth/signin"

# =============================================================================
# EMAIL (OPTIONAL)
# =============================================================================
EMAIL_HOST=""
EMAIL_PORT=587
EMAIL_USER=""
EMAIL_PASSWORD=""
EMAIL_SENDER=""
EMAIL_TLS=true

# Contact form destination
CONTACT_EMAIL=""

# =============================================================================
# CMS CONFIGURATION
# =============================================================================
CMS_CLIENT="keystatic"
NEXT_PUBLIC_KEYSTATIC_CONTENT_PATH="./content"
NEXT_PUBLIC_LOCALES_PATH="public/locales"

# =============================================================================
# FEATURE FLAGS (OPTIONAL)
# =============================================================================
NEXT_PUBLIC_ENABLE_THEME_TOGGLE="true"
NEXT_PUBLIC_ENABLE_PERSONAL_ACCOUNT_DELETION="false"
NEXT_PUBLIC_ENABLE_TEAM_ACCOUNTS="true"
NEXT_PUBLIC_ENABLE_TEAM_ACCOUNTS_CREATION="true"
NEXT_PUBLIC_ENABLE_TEAM_ACCOUNTS_DELETION="false"
NEXT_PUBLIC_LANGUAGE_PRIORITY="application"

# =============================================================================
# EXTERNAL SERVICES (OPTIONAL)
# =============================================================================
# Supabase
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Captcha
NEXT_PUBLIC_CAPTCHA_SITE_KEY=""

# =============================================================================
# DEVELOPMENT/CI (OPTIONAL)
# =============================================================================
NEXT_PUBLIC_CI=""
SKIP_ENV_VALIDATION=""
NEXT_TELEMETRY_DISABLED="1"

# =============================================================================
# UI CONFIGURATION (OPTIONAL)
# =============================================================================
NEXT_PUBLIC_HOME_SIDEBAR_COLLAPSED="false"
