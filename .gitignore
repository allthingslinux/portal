# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (all workspaces)
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js (all workspaces)
.next/
/out/

# turborepo
.turbo/

# production
/build

# drizzle (generated snapshots are committed, but meta is optional)
# Note: migration SQL files in packages/db/drizzle/ ARE committed

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# environment
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# project references & examples (not shipped)
references/
examples/

# cursor / IDE
.cursor/plans
.cursor/hooks/logs/

# pnpm
.pnpm-store
