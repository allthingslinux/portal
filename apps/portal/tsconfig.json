{
  "extends": "@portal/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "allowJs": true,
    "paths": {
      "@/auth": ["./src/features/auth/lib"],
      "@/auth/*": ["./src/features/auth/lib/*"],
      "@/config": ["./src/shared/config"],
      "@/config/*": ["./src/shared/config/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules/**", "references/**"]
}
