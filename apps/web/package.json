{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "analyze": "ANALYZE=true pnpm run build",
    "build": "next build",
    "build:test": "NODE_ENV=test next build",
    "clean": "git clean -xdf .next .turbo node_modules",
    "dev": "next dev | pino-pretty -c",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check \"**/*.{ts,tsx}\" --ignore-path=\"../../.prettierignore\"",
    "start": "next start",
    "start:test": "NODE_ENV=test next start",
    "typecheck": "tsc --noEmit",
    "supabase": "supabase",
    "supabase:start": "supabase status || supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:status": "supabase status",
    "supabase:test": "supabase db test",
    "supabase:db:lint": "supabase db lint",
    "supabase:db:diff": "supabase db diff",
    "supabase:deploy": "supabase link --project-ref $SUPABASE_PROJECT_REF && supabase db push",
    "supabase:typegen": "pnpm run supabase:typegen:packages && pnpm run supabase:typegen:app",
    "supabase:typegen:packages": "supabase gen types typescript --local > ../../packages/supabase/src/database.types.ts",
    "supabase:typegen:app": "supabase gen types typescript --local > ./lib/database.types.ts",
    "supabase:db:dump:local": "supabase db dump --local --data-only"
  },
  "dependencies": {
    "@edge-csrf/nextjs": "2.5.3-cloudflare-rc1",
    "@hookform/resolvers": "^5.2.2",
    "@makerkit/data-loader-supabase-core": "^0.0.10",
    "@makerkit/data-loader-supabase-nextjs": "^1.2.5",
    "@marsidev/react-turnstile": "^1.3.1",
    "@nosecone/next": "1.0.0-beta.13",
    "@portal/accounts": "workspace:*",
    "@portal/admin": "workspace:*",
    "@portal/analytics": "workspace:*",
    "@portal/auth": "workspace:*",
    "@portal/cms": "workspace:*",
    "@portal/database-webhooks": "workspace:*",
    "@portal/email-templates": "workspace:*",
    "@portal/i18n": "workspace:*",
    "@portal/mailers": "workspace:*",
    "@portal/monitoring": "workspace:*",
    "@portal/next": "workspace:*",
    "@portal/notifications": "workspace:*",
    "@portal/shared": "workspace:*",
    "@portal/supabase": "workspace:*",
    "@portal/team-accounts": "workspace:*",
    "@portal/ui": "workspace:*",
    "@radix-ui/react-icons": "^1.3.2",
    "@supabase/supabase-js": "2.78.0",
    "@tanstack/react-query": "5.90.5",
    "@tanstack/react-table": "^8.21.3",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.44.7",
    "lucide-react": "^0.552.0",
    "next": "catalog:",
    "next-sitemap": "^4.2.3",
    "next-themes": "0.4.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.66.0",
    "react-i18next": "^16.2.3",
    "recharts": "2.15.3",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "catalog:",
    "urlpattern-polyfill": "^10.1.0",
    "zod": "^3.25.74"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "catalog:",
    "@portal/eslint-config": "workspace:*",
    "@portal/prettier-config": "workspace:*",
    "@portal/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "babel-plugin-react-compiler": "1.0.0",
    "cssnano": "^7.1.2",
    "pino-pretty": "13.0.0",
    "prettier": "^3.6.2",
    "supabase": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "^5.9.3"
  },
  "prettier": "@portal/prettier-config",
  "browserslist": [
    "last 1 versions",
    "> 0.7%",
    "not dead"
  ]
}
