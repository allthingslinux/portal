{
  "entry": [
    "src/app/**/{page,layout,loading,error,not-found}.{ts,tsx}!",
    "src/app/**/route.ts!",
    "src/app/**/{page,layout,loading,error,not-found}.js!",
    "src/app/**/route.js!",
    "next.config.ts",
    "postcss.config.mjs",
    "src/core/database/migrate.ts",
    "src/core/database/seed.ts",
    "src/core/database/create-better-auth-tables.ts",
    "src/core/database/drizzle.config.js",
    "src/core/database-webhooks/index.ts"
  ],
  "project": ["src/**/*.{ts,tsx}!", "!src/**/*.stories.{ts,tsx}!"],
  "paths": {
    "~/*": ["./src/app/*"],
    "~/config/*": ["./src/core/config/*"],
    "~/components/*": ["./src/shared/components/*"],
    "~/core/*": ["./src/core/*"],
    "~/features/*": ["./src/features/*"],
    "~/shared/*": ["./src/shared/*"],
    "~/tools/*": ["./src/tools/*"]
  },
  "ignore": [
    "**/node_modules/**",
    "**/.next/**",
    "**/dist/**",
    "**/build/**",
    "**/*.d.ts"
  ],
  "ignoreDependencies": ["@types/*"]
}
