{
  "entry": [
    "src/app/**/{page,layout,loading,error,not-found}.{ts,tsx}",
    "src/app/**/route.ts",
    "src/components/**",
    "src/lib/**",
    "src/config/**"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "!src/**/*.test.{ts,tsx}",
    "!src/**/*.spec.{ts,tsx}",
    "!src/**/*.stories.{ts,tsx}"
  ],
  "paths": {
    "~/*": ["./src/app/*"],
    "~/config/*": ["./src/config/*"],
    "~/components/*": ["./src/components/*"],
    "~/lib/*": ["./src/lib/*"],
    "~/packages/*": ["./src/packages/*"]
  },
  "ignore": [
    "**/node_modules/**",
    "**/.next/**",
    "**/dist/**",
    "**/build/**",
    "**/*.d.ts"
  ],
  "ignoreDependencies": [
    "@types/*",
    "next",
    "react",
    "react-dom",
    "typescript",
    "eslint"
  ]
}
