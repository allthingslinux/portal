{
  "name": "portal",
  "version": "0.1.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "analyze": "ANALYZE=true bun run build",
    "build": "next build",
    "build-keycloak": "cd packages/keycloak-theme && npm run build-keycloak-theme",
    "clean": "git clean -xdf .next node_modules",
    "dev": "next dev | pino-pretty -c",
    "dev-keycloak": "cd packages/keycloak-theme && npm run storybook",
    "deploy:theme": "./scripts/deploy-theme.sh",
    "lint": "ultracite check",
    "lint:fix": "ultracite fix",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "db:migrate": "bun run src/lib/database/migrate.ts",
    "db:seed": "bun run src/lib/database/seed.ts",
    "db:setup": "bun run src/lib/database/migrate.ts && bun run src/lib/database/seed.ts",
    "db:create-better-auth-tables": "bun run src/lib/database/create-better-auth-tables.ts",
    "db:push": "bunx drizzle-kit push --config=src/lib/database/drizzle.config.js",
    "db:generate": "bunx drizzle-kit generate --config=src/lib/database/drizzle.config.js",
    "db:studio": "bunx drizzle-kit studio --config=src/lib/database/drizzle.config.js",
    "knip": "bunx knip"
  },
  "dependencies": {
    "@edge-csrf/nextjs": "2.5.3-cloudflare-rc1",
    "@hookform/resolvers": "^5.2.2",
    "@markdoc/markdoc": "^0.5.4",
    "@marsidev/react-turnstile": "^1.4.0",
    "@nosecone/next": "1.0.0-beta.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@react-email/components": "1.0.2",
    "@sentry/nextjs": "^10.32.0",
    "@sindresorhus/slugify": "^3.0.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tanstack/react-query": "5.90.12",
    "@tanstack/react-table": "^8.21.3",
    "@types/bcryptjs": "^3.0.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.4.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "i18next": "25.7.3",
    "i18next-browser-languagedetector": "8.2.0",
    "i18next-resources-to-backend": "^1.2.1",
    "input-otp": "1.4.2",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.562.0",
    "nanoid": "^5.1.6",
    "next": "^16.1.0",
    "next-devtools-mcp": "^0.3.7",
    "next-themes": "0.4.6",
    "node-html-parser": "^7.0.1",
    "nodemailer": "^7.0.11",
    "pino": "^10.1.0",
    "postgres": "3.4.7",
    "radix-ui": "1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.13.0",
    "react-dom": "19.2.3",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.68.0",
    "react-i18next": "^16.5.0",
    "react-top-loading-bar": "3.0.2",
    "recharts": "3.6.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "totp-generator": "^2.0.0",
    "tw-animate-css": "1.4.0",
    "urlpattern-polyfill": "^10.1.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@keystatic/core": "0.5.48",
    "@keystatic/next": "^5.0.4",
    "@next/bundle-analyzer": "16.1.0",
    "@tailwindcss/postcss": "4.1.18",
    "@types/bun": "^1.3.4",
    "@types/node": "25.0.3",
    "@types/nodemailer": "7.0.4",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.23",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.9.10",
    "cross-env": "^10.1.0",
    "cssnano": "^7.1.2",
    "dotenv": "17.2.3",
    "drizzle-kit": "^0.31.8",
    "postcss": "^8.5.6",
    "next-sitemap": "^4.2.3",
    "pino-pretty": "13.1.3",
    "tailwindcss": "4.1.18",
    "typescript": "^5.9.3",
    "ultracite": "6.5.1",
    "wp-types": "^4.69.0"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "author": {
    "name": "All Things Linux"
  },
  "browserslist": [
    "last 1 versions",
    "> 0.7%",
    "not dead"
  ]
}