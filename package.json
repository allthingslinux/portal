{
  "name": "portal",
  "version": "0.1.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "analyze": "ANALYZE=true bun run build",
    "build": "next build",
    "build:test": "NODE_ENV=test next build",
    "clean": "git clean -xdf .next node_modules",
    "dev": "next dev | pino-pretty -c",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check \"**/*.{ts,tsx}\"",
    "start": "next start",
    "start:test": "NODE_ENV=test next start",
    "typecheck": "tsc --noEmit",
    "supabase": "bunx supabase",
    "supabase:start": "bunx supabase status || bunx supabase start",
    "supabase:stop": "bunx supabase stop",
    "supabase:reset": "bunx supabase db reset",
    "supabase:status": "bunx supabase status",
    "supabase:test": "bunx supabase db test",
    "supabase:db:lint": "bunx supabase db lint",
    "supabase:db:diff": "bunx supabase db diff",
    "supabase:deploy": "bunx supabase link --project-ref $SUPABASE_PROJECT_REF && bunx supabase db push",
    "supabase:typegen": "bun run supabase:typegen:packages && bun run supabase:typegen:app",
    "supabase:typegen:packages": "bunx supabase gen types typescript --local > ./src/core/database/supabase/database.types.ts",
    "supabase:typegen:app": "bunx supabase gen types typescript --local > ./src/shared/lib/database.types.ts",
    "supabase:db:dump:local": "bunx supabase db dump --local --data-only",
    "report": "playwright show-report",
    "test": "playwright test --max-failures=1",
    "test:fast": "playwright test --max-failures=1 --workers=16",
    "test:setup": "playwright test tests/auth.setup.ts",
    "test:ui": "playwright test --ui"
  },
  "dependencies": {
    "@edge-csrf/nextjs": "2.5.3-cloudflare-rc1",
    "@hookform/resolvers": "^5.2.2",
    "@makerkit/data-loader-supabase-core": "^0.0.10",
    "@makerkit/data-loader-supabase-nextjs": "^1.2.5",
    "@markdoc/markdoc": "^0.5.4",
    "@marsidev/react-turnstile": "^1.3.1",
    "@modelcontextprotocol/sdk": "1.20.2",
    "@nosecone/next": "1.0.0-beta.13",
    "@radix-ui/react-icons": "^1.3.2",
    "@react-email/components": "0.5.7",
    "@sentry/nextjs": "^10.22.0",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "2.78.0",
    "@tanstack/react-query": "5.90.5",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.44.7",
    "i18next": "25.6.0",
    "i18next-browser-languagedetector": "8.2.0",
    "i18next-resources-to-backend": "^1.2.1",
    "input-otp": "1.4.2",
    "jwt-decode": "^4.0.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.552.0",
    "nanoid": "^5.1.6",
    "next": "^16.0.1",
    "next-themes": "0.4.6",
    "node-html-parser": "^7.0.1",
    "nodemailer": "^7.0.10",
    "pino": "^10.1.0",
    "postgres": "3.4.7",
    "radix-ui": "1.4.3",
    "react": "19.2.0",
    "react-day-picker": "^9.11.1",
    "react-dom": "19.2.0",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.66.0",
    "react-i18next": "^16.2.3",
    "react-top-loading-bar": "3.0.2",
    "recharts": "2.15.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "totp-generator": "^2.0.0",
    "tw-animate-css": "1.4.0",
    "urlpattern-polyfill": "^10.1.0",
    "zod": "^3.25.74"
  },
  "devDependencies": {
    "@types/bun": "^1.3.1",
    "@types/node": "24.9.2",
    "@types/nodemailer": "7.0.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "typescript": "^5.9.3",
    "@next/bundle-analyzer": "16.0.1",
    "@next/eslint-plugin-next": "^16.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "cross-env": "^10.0.0",
    "dotenv": "17.2.3",
    "next-sitemap": "^4.2.3",
    "@playwright/test": "^1.56.1",
    "drizzle-kit": "^0.31.6",
    "supabase": "2.54.11",
    "@keystatic/core": "0.5.48",
    "@keystatic/next": "^5.0.4",
    "wp-types": "^4.68.3",
    "@eslint/config-helpers": "^0.1.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.0.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "@trivago/prettier-plugin-sort-imports": "5.2.2",
    "@tailwindcss/postcss": "4.1.16",
    "autoprefixer": "^10.4.21",
    "cssnano": "^7.1.2",
    "tailwindcss": "4.1.16",
    "pino-pretty": "13.0.0"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "author": {
    "name": "All Things Linux"
  },
  "browserslist": [
    "last 1 versions",
    "> 0.7%",
    "not dead"
  ]
}