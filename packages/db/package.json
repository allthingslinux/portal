{
  "name": "@portal/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    },
    "./schema/*": {
      "types": "./src/schema/*.ts",
      "default": "./src/schema/*.ts"
    }
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config src/config.ts",
    "db:migrate": "drizzle-kit migrate --config src/config.ts",
    "db:push": "drizzle-kit push --config src/config.ts",
    "db:studio": "drizzle-kit studio --config src/config.ts"
  },
  "dependencies": {
    "@portal/types": "workspace:*",
    "@t3-oss/env-nextjs": "^0.13.10",
    "drizzle-orm": "1.0.0-beta.9-e89174b",
    "pg": "^8.17.1",
    "server-only": "^0.0.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@portal/typescript-config": "workspace:*",
    "@types/pg": "^8.16.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "1.0.0-beta.15-859cf75",
    "typescript": "^5.9.3"
  }
}
