{
  "name": "@portal/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./*": {
      "types": "./src/*.tsx",
      "default": "./src/*.tsx"
    },
    "./ui/button-variants": {
      "types": "./src/ui/button-variants.ts",
      "default": "./src/ui/button-variants.ts"
    },
    "./layout": {
      "types": "./src/layout/index.ts",
      "default": "./src/layout/index.ts"
    },
    "./layout/header": {
      "types": "./src/layout/header/index.ts",
      "default": "./src/layout/header/index.ts"
    },
    "./layout/navigation": {
      "types": "./src/layout/navigation/index.ts",
      "default": "./src/layout/navigation/index.ts"
    },
    "./layout/page": {
      "types": "./src/layout/page/index.ts",
      "default": "./src/layout/page/index.ts"
    },
    "./layout/sidebar": {
      "types": "./src/layout/sidebar/index.ts",
      "default": "./src/layout/sidebar/index.ts"
    }
  },
  "scripts": {
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@daveyplate/better-auth-ui": "^3.3.15",
    "@portal/types": "workspace:*",
    "@portal/utils": "workspace:*",
    "@base-ui/react": "^1.1.0",
    "@radix-ui/react-label": "^2.1.8",
